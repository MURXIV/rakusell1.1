SECRET_KEY=rakusell-super-secret-key-change-in-production-2024
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,*

DATABASE_URL=postgres://rakusell:rakusell_pass@db:5432/rakusell

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Green-API — регистрация на green-api.com, создать инстанс и вставить ID и токен
GREEN_API_INSTANCE_ID=710XXXXXXX
GREEN_API_TOKEN=<токен из личного кабинета green-api.com>
GREEN_API_BASE_URL=https://api.green-api.com

# AI-провайдер: deepseek / openai / gemini
AI_PROVIDER=deepseek
AI_MODEL=deepseek-chat
AI_MAX_TOKENS=1000
AI_HISTORY_LIMIT=20

# API-ключи провайдеров (нужен только тот, который указан в AI_PROVIDER)
DEEPSEEK_API_KEY=<ключ из platform.deepseek.com>
OPENAI_API_KEY=
GEMINI_API_KEY=

CHROMA_HOST=chroma
CHROMA_PORT=8000
CHROMA_COLLECTION=rakusell_knowledge

JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
WEBHOOK_SECRET=

RAG_DISTANCE_THRESHOLD=0.7
RAG_TOP_K=5
RAG_EMBEDDING_MODEL=text-embedding-3-small
